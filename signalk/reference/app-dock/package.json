{
  "name": "@signalk/app-dock",
  "version": "0.3.1",
  "description": "macOS-style configurable app dock for switching between SignalK webapps on touch screens",
  "repository": {
    "url": "https://github.com/SignalK/app-dock"
  },
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-webapp",
    "signalk-plugin-configurator",
    "signalk-category-instruments"
  ],
  "signalk-plugin-enabled-by-default": true,
  "signalk": {
    "displayName": "App Dock",
    "appIcon": "./app-icon.svg"
  },
  "main": "plugin/index.js",
  "scripts": {
    "build:config": "webpack",
    "prepublishOnly": "webpack",
    "format": "prettier --write '**/*.{js,json,md,css,html}' && eslint --fix .",
    "lint": "eslint .",
    "test": "node --test test/plugin.test.js"
  },
  "author": "",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "babel-loader": "^10.1.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2"
  }
}
